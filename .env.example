APP_NAME="Piler Archive Extractor API"
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=Africa/Tunis
APP_URL=http://localhost:8000

USE_REAL_DB=false
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=piler_archive
DB_USER=root
DB_PASS=secret

USE_SQL_DUMP=true
SQL_DUMP_PATH=piler_backup.sql
SQL_DUMP_MAX_EMAILS=0
SQL_DUMP_MEMORY_LIMIT=1024M

AI_ENABLED=false
AI_PROVIDER=mock
AI_BATCH_SIZE=50

APP_DB_DRIVER=sqlite
APP_DB_PATH=storage/database/app.sqlite

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now

SESSION_NAME=piler_admin_session
SESSION_LIFETIME_MINUTES=120
